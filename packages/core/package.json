{
  "name": "@conovel/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agents/*": {
      "types": "./dist/agents/*/index.d.ts",
      "import": "./dist/agents/*/index.js"
    },
    "./state/*": {
      "types": "./dist/state/*.d.ts",
      "import": "./dist/state/*.js"
    },
    "./memory/*": {
      "types": "./dist/memory/*.d.ts",
      "import": "./dist/memory/*.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src/"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "typescript": "^5.7.0"
  }
}
