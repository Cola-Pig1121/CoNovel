{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-tauri/main/tauri.conf.schema.json",
  "productName": "CoNovel",
  "identifier": "com.conovel.app",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../packages/studio/out",
    "devUrl": "http://localhost:3002",
    "beforeDevCommand": "pnpm --filter @conovel/studio dev",
    "beforeBuildCommand": "pnpm --filter @conovel/studio build"
  },
  "app": {
    "windows": [
      {
        "title": "CoNovel - 自进化多Agent小说写作系统",
        "width": 1400,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/Cola-Pig1121/CoNovel/releases/latest/download/latest.json"
      ]
    }
  }
}
